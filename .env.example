# ============================================================
# ATTEST — Environment Variables
# ============================================================
#
# HOW TO USE:
#   1. Copy this file:   copy .env.example .env
#   2. Fill in your keys below (uncomment the ones you need)
#   3. Run:              attest test-connection
#
# IMPORTANT: Never commit .env to git (it's in .gitignore)
# ============================================================


# ============================================================
# AGENT AUTHENTICATION
# ============================================================
# This key authenticates to your agent under test (Foundry).
# Find it at: https://ai.azure.com → Your Project → Settings → Keys
#
# KEYLESS OPTION: Leave this blank and run 'az login' first.
# ATTEST will auto-authenticate via Azure Entra ID (no key needed).

AZURE_API_KEY=paste-your-foundry-agent-key-here


# ============================================================
# LLM JUDGE — For evaluators, AI test gen, user simulation
# ============================================================
# The LLM judge scores agent responses (correctness, relevancy, etc.)
# Not needed if you only use assertions (free, no LLM call).
#
# KEYLESS OPTION: Leave keys blank, just set AZURE_API_BASE.
# Run 'az login' first, and ATTEST uses Azure Entra ID automatically.
# Requires: pip install azure-identity
#
# You need ONE of the options below.

# --- Option A: Azure OpenAI (recommended if you're already on Azure) ---
# Works with GPT models deployed on Azure OpenAI Service.
# The endpoint is your Azure OpenAI resource (NOT the Foundry endpoint).
# The key can be the same as AZURE_API_KEY if both are on the same resource.
# OR: leave AZURE_API_KEY_OPENAI blank for keyless Entra ID auth.
#
AZURE_API_BASE=https://your-resource-name.openai.azure.com
AZURE_API_KEY_OPENAI=paste-your-azure-openai-key-here
AZURE_API_VERSION=2025-04-01-preview

# --- Option B: Standard OpenAI (if you have an OpenAI API key) ---
# Works for both built-in evaluators and DeepEval evaluators natively.
#
# OPENAI_API_KEY=sk-paste-your-openai-key-here

# --- Option C: Anthropic (for Claude as LLM judge) ---
# Only works for built-in evaluators (5). DeepEval still needs OpenAI/Azure.
# Set model in attest.yaml to: "anthropic/claude-sonnet-4-20250514"
#
# ANTHROPIC_API_KEY=sk-ant-paste-your-key-here


# ============================================================
# AZURE AI EVALUATION SDK (optional)
# ============================================================
# Only needed if you use the 15 Azure AI evaluators.
# These are the Azure resource details, NOT the OpenAI key.
#
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=your-resource-group
# AZURE_PROJECT_NAME=your-ai-project-name
